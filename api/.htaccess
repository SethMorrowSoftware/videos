# Archive Film Club - API Directory .htaccess
# Ensures PHP files are processed correctly

# Enable PHP processing
<IfModule mod_mime.c>
    AddHandler application/x-httpd-php .php
</IfModule>

# NOTE: CORS headers intentionally NOT set here. The API is same-origin.
# A previous version emitted "Access-Control-Allow-Origin: *" which let any
# remote origin POST to the cache/auth endpoints. If you ever need CORS,
# restrict it to your APP_URL explicitly rather than using a wildcard.

# Disable directory listing
Options -Indexes

# Allow access to PHP files (Apache 2.4 syntax)
<FilesMatch "\.php$">
    Require all granted
</FilesMatch>

# diagnose.php is hard-denied at the root .htaccess too, but defense in
# depth: also block it here in case the root rule ever loosens.
<Files "diagnose.php">
    Require all denied
</Files>
