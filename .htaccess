# Archive Film Club - Root .htaccess
# Tested on Apache 2.4 (the default on every supported cPanel host).

# Enable rewrite engine
<IfModule mod_rewrite.c>
    RewriteEngine On

    # ---- HTTPS-only enforcement (uncomment after SSL is installed) ----
    # Many cPanel sites issue SSL via AutoSSL on first launch. Leaving the
    # block below uncommented before the cert is in place results in a 301
    # redirect to a URL that fails SSL handshake -- and the 301 is cached
    # by browsers, so users have to clear their cache later. Enable AFTER
    # you've confirmed https:// loads correctly.
    #
    # The `X-Forwarded-Proto != https` guard avoids redirect loops behind
    # Cloudflare flexible SSL / LiteSpeed proxy / any reverse proxy that
    # terminates TLS upstream.
    #
    # RewriteCond %{HTTPS} off
    # RewriteCond %{HTTP:X-Forwarded-Proto} !=https
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Handle PHP files directly - don't rewrite them
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^.*\.php$ - [L]

    # Handle existing files and directories
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]
</IfModule>

# Ensure PHP files are processed
<IfModule mod_mime.c>
    AddType application/x-httpd-php .php
</IfModule>

# Security headers
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
    Header set Cross-Origin-Opener-Policy "same-origin"

    # HSTS: uncomment ALONGSIDE the HTTPS redirect block above, once your
    # SSL cert is stable. Once browsers see this header they refuse to load
    # the site over plain HTTP for the next year, so don't enable until
    # you're confident HTTPS works.
    # Header set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    # CSP: lenient default that allows the inline brand-color <style> blocks
    # and inline event handlers still used by admin.js. Tighten over time
    # by replacing inline handlers with addEventListener and inline styles
    # with classes, then drop 'unsafe-inline'.
    Header set Content-Security-Policy "default-src 'self'; img-src 'self' data: https://archive.org https://*.archive.org; media-src 'self' https://archive.org https://*.archive.org; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://archive.org https://*.archive.org; frame-ancestors 'self'; base-uri 'self'; form-action 'self'"
</IfModule>

# Security - Deny access to sensitive files (Apache 2.4 syntax)
<FilesMatch "^\.env">
    Require all denied
</FilesMatch>

<FilesMatch "^(config\.php|Database\.php|bootstrap\.php)$">
    Require all denied
</FilesMatch>

# Block direct web access to legacy upgrade script
<FilesMatch "^upgrade_cache\.php$">
    Require all denied
</FilesMatch>

# BEFORE INSTALL: install.php must be reachable so the setup wizard can
# run. The wizard self-locks via the .installed file (and via the admin-
# already-exists check in install.php) once you've created an admin, so
# leaving install.php briefly reachable during setup is safe.
#
# AFTER INSTALL: uncomment the FilesMatch block below to block all web
# access at the server level (defense-in-depth alongside the .installed
# lock). The cleanest move is to just delete install.php from the server
# once setup is done -- the deny block is a fallback if you'd rather keep
# the file around for future re-installs.
#
# <FilesMatch "^install\.php$">
#     Require all denied
# </FilesMatch>

# diagnose.php exposes infrastructure info; keep it admin-only and prefer
# to delete the file once you've confirmed everything works.
<Files "diagnose.php">
    Require all denied
</Files>

# Block dev / dotfile leakage
<FilesMatch "\.(md|sql|log|sample|example|ini|lock|bak|swp|swo)$">
    Require all denied
</FilesMatch>

<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# Block JSON fallback files from direct fetch -- they're read server-side
# and may contain settings the admin would rather not advertise. Comment
# this out if you want them browseable.
<FilesMatch "^(site-settings|recommendations|featured-sections)\.json$">
    Require all denied
</FilesMatch>

# Deny access to source / data directories that should never be web-served.
# NOTE: src/js/ is browser-loaded ES module code -- it MUST stay reachable
# (which is why we don't include 'services' or 'db' broadly here -- they
# match inside /src/js/services/ too). Each of those server-side dirs
# instead ships its own deny-all .htaccess so subdirectory installs work
# without us having to write a positional regex.
RedirectMatch 404 (^|/)(electron|node_modules|logs)(/|$)

# Disable directory listing
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
    ExpiresByType image/x-icon "access plus 1 month"
    ExpiresByType application/manifest+json "access plus 1 week"
</IfModule>

# Friendly error pages.
#
# ErrorDocument paths are resolved from the server's document root, NOT
# from this .htaccess. For a root install at https://example.com/ the
# defaults below are correct.
#
# Subdirectory installs (e.g. /films/) need to PREFIX these with the
# subdirectory:
#   ErrorDocument 404 /films/404.php
#   ErrorDocument 403 /films/404.php
#   ErrorDocument 500 /films/500.php
# Otherwise Apache will look for /404.php at the document root and miss,
# falling back to its default error page. (Functional but not branded.)
ErrorDocument 404 /404.php
ErrorDocument 403 /404.php
ErrorDocument 500 /500.php
